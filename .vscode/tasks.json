{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "biome lint whole project",
      "type": "process",
      "command": "pnpm",
      "args": ["run", "lint", "--reporter=github"],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "biome",
        "source": "biome",
        "pattern": [
          {
            "regexp": "^::(?<severity>\\S+)\\s+title=(?<title>.+),file=(?<file>.+),line=(?<line>\\d+),endLine=(?<endLine>\\d+),col=(?<col>\\d+),endColumn=(?<endColumn>\\d+)::(?<message>.+)$",
            "kind": "location",
            "severity": 1,
            "code": 2,
            "file": 3,
            "line": 4,
            "endLine": 5,
            "column": 6,
            "endColumn": 7,
            "message": 8
          }
        ]
      }
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "pnpm typecheck",
      "problemMatcher": "$tsc",
      "group": "test",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "typecheck: watch",
      "type": "shell",
      "command": "pnpm typecheck --watch",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "tokens: build",
      "type": "shell",
      "command": "pnpm tokens"
    },
    {
      "label": "next: dev",
      "type": "shell",
      "command": "pnpm dev",
      "isBackground": true,
      "presentation": {
        "panel": "dedicated"
      }
    },
    {
      "label": "storybook: dev",
      "type": "shell",
      "command": "pnpm storybook",
      "isBackground": true,
      "presentation": {
        "panel": "dedicated"
      }
    },
    {
      "label": "test-storybook",
      "type": "shell",
      "command": "pnpm test-storybook"
    },
    {
      "label": "dev: everything",
      "dependsOn": ["next: dev", "storybook: dev", "typecheck: watch"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
