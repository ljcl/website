{
  "$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!.zed/settings.json"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "domains": {
      "next": "recommended",
      "project": "recommended",
      "react": "recommended",
      "test": "recommended"
    },
    "rules": {
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        }
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": {
          "level": "error",
          "options": {
            "style": "inlineType"
          }
        }
      },
      "nursery": {
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": {
            "functions": ["clsx", "cn", "twMerge"]
          }
        },
        "noReactForwardRef": "error",
        "noContinue": "error",
        "noDeprecatedImports": "error",
        "noImportCycles": "error",
        "noIncrementDecrement": "error",
        "noJsxLiterals": "error",
        "noMisusedPromises": "error",
        "noFloatingPromises": "error",
        "noNextAsyncClientComponent": "error",
        "noParametersOnlyUsedInRecursion": "error",
        "noShadow": "error",
        "noUnknownAttribute": "error",
        "noUnnecessaryConditions": "error",
        "noUnusedExpressions": "error",
        "noUselessCatchBinding": "error",
        "noUselessUndefined": "error",
        "useArraySortCompare": "error",
        "useConsistentArrowReturn": "error",
        "useExhaustiveSwitchCases": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "parser": {
      "tailwindDirectives": true,
      "cssModules": true
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "trailingCommas": "none",
      "indentWidth": 2
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "recommended": true,
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [{ "type": false }]
          }
        },
        "useSortedProperties": "on"
      }
    }
  }
}
