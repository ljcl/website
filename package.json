{
  "name": "lukeclark",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24.0.0",
    "pnpm": "10.33.2"
  },
  "packageManager": "pnpm@10.33.2",
  "imports": {
    "#.storybook/*": [
      "./.storybook/*"
    ],
    "#util/*": "./util/*",
    "#components/*": "components/*",
    "#lib/*": "lib/*"
  },
  "scripts": {
    "tokens": "node scripts/build-tokens.ts",
    "dev": "pnpm tokens && NODE_OPTIONS='--inspect' next dev",
    "analyze": "pnpm tokens && ANALYZE=true next build",
    "build": "pnpm tokens && next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "preinstall": "npx -y only-allow pnpm",
    "postinstall": "pnpm tokens",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test-storybook": "vitest --project=storybook"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/bundle-analyzer": "16.2.4",
    "@next/mdx": "16.2.4",
    "@next/third-parties": "16.2.4",
    "@opentelemetry/api": "^1.9.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/otel": "^2.1.2",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "codehike": "^1.1.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recma-codehike": "^0.0.1",
    "remark-codehike": "^0.0.1",
    "remark-gfm": "^4.0.1",
    "seti-icons": "^0.0.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "lefthook": "^2.1.6",
    "playwright": "^1.59.1",
    "postcss": "^8.5.13",
    "storybook": "^10.3.6",
    "style-dictionary": "^5.4.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
